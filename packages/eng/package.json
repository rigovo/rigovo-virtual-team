    "test:watch": "vitest"
  },
  "dependencies": {
    "@rigovo/core": "workspace:*",
    "@rigour-labs/core": "^4.0.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
