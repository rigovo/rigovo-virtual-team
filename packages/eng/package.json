{
  "name": "@rigovo/eng",
  "version": "0.1.0",
  "description": "Engineering agents — Coder, Reviewer, QA, Planner, Lead, SRE, DevOps",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
