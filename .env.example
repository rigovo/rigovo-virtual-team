# ── Rigovo Teams — Environment Config (Example) ───────────────────────
#
# Copy this to .env and adjust as needed.
#
# IMPORTANT: Do NOT put API keys or passwords here.
# Use Settings UI instead — secrets are encrypted at rest in SQLite
# (Fernet AES-128 + OS Keychain).
# ──────────────────────────────────────────────────────────────────────

# Identity provider: "workos" (production) | "local" (offline dev)
RIGOVO_IDENTITY_PROVIDER="workos"

# Auth mode: "email_only" | "hybrid" | "sso_required"
RIGOVO_AUTH_MODE="hybrid"

# Override WorkOS redirect URI (default: http://127.0.0.1:8787/v1/auth/callback)
# WORKOS_REDIRECT_URI="http://127.0.0.1:8787/v1/auth/callback"
